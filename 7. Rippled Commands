
# MANUALLY UPDATE THE RIPPLED VERSION (SET)
===========================================
sudo apt -y update
sudo apt -y upgrade rippled
sudo systemctl daemon-reload
sudo systemctl restart rippled

# VIEW RIPPLED STATUS
=====================
sudo rippled server_info

# RESTART RIPPLED SERVICE
=========================
sudo systemctl restart rippled.service

# VIEW RIPPLED PEERS
====================
sudo rippled peers

# OPEN THE RIPPLED CONFIG FILE
==============================
sudo nano /etc/opt/ripple/rippled.cfg

# OPEN THE VALIDATORS TEXT FILE
=================================
sudo nano /etc/opt/ripple/validators.txt

# EXMAPLES TO VOTE FOR AN AMENDMENT VIA THE CLI 
===============================================
rippled feature SHAMapV2 reject
rippled feature SHAMapV2 reject

# EXAMPLES TO VOTE FOR AN AMENDMENT VIA THE CONFIG FILE
=======================================================
[rpc_startup]
{ "command": "feature", "feature": "MPTokensV1", "vetoed": false }
{ "command": "feature", "feature": "Batch", "vetoed": false }

